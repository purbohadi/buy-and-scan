# Copy to .env (gitignored). Used by Wrangler CLI, deploy/secrets scripts, and local dev.

# deploy + secrets: development = scan-and-parse-dev, production = scan-and-parse-production
ENV_MODE=development

# Optional: Google Search Console HTML tag verification (injected into index.html at build time)
# VITE_GOOGLE_SITE_VERIFICATION=

# --- Cloudflare CLI (optional; account_id is also in wrangler.jsonc) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Google OAuth (Wrangler / local Worker) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random string (32+ chars): session cookies + encrypts Google refresh tokens in D1
AUTH_SESSION_SECRET=

# --- Receipt vision AI (parse chain) ---
# RECEIPT_AI_PROVIDER: omit or `auto` (default in wrangler) = OpenAI (if OPENAI_API_KEY) → OpenRouter (if key) → Workers AI
# Force single provider: `workers` | `openai` | `openrouter`
# RECEIPT_AI_PROVIDER=auto
# Optional override order when auto (comma-separated): openai,openrouter,workers
# RECEIPT_AI_FALLBACK_CHAIN=openai,workers
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# RECEIPT_VISION_MODEL=gpt-4o-mini
